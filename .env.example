# Example .env file for Samba Service

# MongoDB connection string
MONGODB_URI='your_mongodb_uri'

# JWT secret key
JWT_SECRET='your_jwt_secret'

# Cloudinary configuration
CLOUDINARY_URL='your_cloudinary_url'

# Payment API keys
PAYMENT_API_KEY='your_payment_api_key'
PAYMENT_API_SECRET='your_payment_api_secret'

# Seed script credentials (required when running src/seed.js)
SEED_ADMIN_EMAIL='admin@samba.com'
SEED_ADMIN_PASSWORD='your_admin_password'
SEED_USER1_EMAIL='alice@samba.com'
SEED_USER1_PASSWORD='your_user1_password'
SEED_USER2_EMAIL='bob@samba.com'
SEED_USER2_PASSWORD='your_user2_password'