# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/samba_service
DB_NAME=samba_service

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=30d

# Server
PORT=5000
NODE_ENV=development

# Orange Money
ORANGE_MONEY_API_KEY=your_orange_money_api_key
ORANGE_MONEY_MERCHANT_ID=your_merchant_id

# Wave
WAVE_API_KEY=your_wave_api_key
WAVE_MERCHANT_ID=your_wave_merchant_id

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@sambaservice.com

# Frontend URL
FRONTEND_URL=http://localhost:3000
